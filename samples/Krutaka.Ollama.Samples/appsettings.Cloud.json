{
  // Ollama Cloud profile. Activate with:
  //   DOTNET_ENVIRONMENT=Cloud dotnet run -- quickstart
  //
  // Sign in at https://ollama.com/ and create an API key at https://ollama.com/settings,
  // then export it (never commit real keys):
  //   export Ollama__ApiKey="sk-..."
  //
  // Cloud models are listed at https://ollama.com/cloud. They use the `-cloud` suffix,
  // e.g. `gpt-oss:120b-cloud`, `qwen3-coder:480b-cloud`.

  "Ollama": {
    "BaseAddress": "https://ollama.com/",
    "DefaultModel": "gpt-oss:120b-cloud",
    // Usual hosted-service timeouts are generous; cloud first-token latency can be several seconds.
    "Timeout": "00:10:00",
    // ApiKey is intentionally NOT set here. Provide it via the Ollama__ApiKey env var.
    "ApiKey": null
  },

  "Samples": {
    "ChatModel": "gpt-oss:120b-cloud",
    // Embeddings are typically run locally against a small model; override if you prefer cloud.
    "EmbeddingModel": "nomic-embed-text",
    "ToolCallingModel": "gpt-oss:120b-cloud"
  }
}
