{
  // Default configuration for the Krutaka.Ollama sample runner.
  //
  // This file is intentionally verbose: it shows every option you can tweak when
  // wiring Krutaka.Ollama in your own app. Strip what you don't need.
  //
  // Override precedence (highest wins):
  //   1. Environment variables (OLLAMA_HOST, OLLAMA_MODEL, Ollama__ApiKey, ...)
  //   2. appsettings.<Environment>.json   (e.g. appsettings.Cloud.json)
  //   3. appsettings.json (this file)
  //
  // Select an environment with either:
  //   DOTNET_ENVIRONMENT=Cloud dotnet run -- quickstart
  //   dotnet run -- quickstart --environment Cloud

  "Ollama": {
    // HTTP endpoint of the Ollama server.
    //   Local  : http://localhost:11434/
    //   Cloud  : https://ollama.com/   (use appsettings.Cloud.json or set DOTNET_ENVIRONMENT=Cloud)
    "BaseAddress": "http://localhost:11434/",

    // Model used when a sample does not override it and OLLAMA_MODEL is unset.
    // Pick a model you have pulled: `ollama pull llama3.2`
    "DefaultModel": "llama3.2",

    // Request timeout for non-streaming calls. Streaming respects the caller's CancellationToken.
    "Timeout": "00:05:00",

    // How long the server keeps the model resident after a request. "-1" = indefinitely.
    "KeepAlive": "00:05:00",

    // Retries on 502/503/504/408 and transport errors. 0 disables retries.
    "MaxRetries": 2,

    // User-Agent header suffix. Helpful when you run multiple apps against the same server.
    "UserAgent": "Krutaka.Ollama.Samples",

    // Bearer token for Ollama Cloud. Leave null for local use. Prefer setting via
    // the Ollama__ApiKey environment variable or user-secrets; do NOT commit real keys.
    "ApiKey": null,

    // Raw Authorization header value. Takes precedence over ApiKey if both are set.
    "AuthorizationHeader": null,

    // Allow plain HTTP to non-loopback addresses. Keep false unless you know what you are doing.
    "AllowInsecureHttp": false
  },

  // Sample-specific knobs. Consumed by the samples themselves, not by the library.
  "Samples": {
    // Overrides Ollama:DefaultModel for chat/generate samples that want a different model
    // from the one used for embeddings (below). Leave null to inherit Ollama:DefaultModel.
    "ChatModel": null,

    // Embedding model. `nomic-embed-text` is small, fast, and free to pull.
    "EmbeddingModel": "nomic-embed-text",

    // Model used by the tool-calling sample. Must support function calling (e.g. llama3.2, qwen2.5).
    "ToolCallingModel": "llama3.2",

    // Number of chunks to print before truncating the streaming sample's output.
    "StreamingMaxChunks": 200
  },

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      // Turn this up to Information to see every HTTP request/response the client makes.
      "Krutaka.Ollama": "Warning"
    }
  }
}
